# ─── Identifiant projet (préfixe tables D1 partagée) ───────────────────
# Doit matcher la constante exportée par src/lib/db/site-id.ts
SITE_ID=coutellerieper

# ─── Variables publiques (accessibles côté client) ─────────────────────
NEXT_PUBLIC_SITE_URL=https://coutellerie-per.fr
NEXT_PUBLIC_MEDIA_BASE=

# ─── Auth (cookie name partagé avec wrangler.jsonc vars) ───────────────
AUTH_COOKIE_NAME=coutellerie_per_session

# ─── Email transactionnel (Resend) ─────────────────────────────────────
# Destinataire interne des notifications formulaire de contact
CONTACT_INBOX=contact@coutellerie-per.fr

# ─── Secrets locaux (dev seulement — utiliser `wrangler secret put` en prod) ───
BETTER_AUTH_SECRET=change-me-min-32-chars-random-string-here
RESEND_API_KEY=re_dev_xxxxxxxxxxxx
